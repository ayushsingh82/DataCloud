# DataCloud — Privacy-Preserving Data Marketplace

# Required: File uploads to IPFS/Filecoin via Lighthouse
# Get your API key at: https://files.lighthouse.storage/
LIGHTHOUSE_API_KEY=your_lighthouse_api_key

# Required: Smart contract addresses (deploy first with ./scripts/deploy.sh)
DATASET_REGISTRY_ADDRESS=
QUERY_MARKET_ADDRESS=

# Server wallet for contract interactions
WALLET_PRIVATE_KEY=

# Filecoin RPC
FILECOIN_RPC_URL=https://api.calibration.node.glif.io/rpc/v1

# Frontend contract addresses (exposed to browser)
NEXT_PUBLIC_QUERY_MARKET_ADDRESS=
NEXT_PUBLIC_DATASET_REGISTRY_ADDRESS=

# Optional: WalletConnect project ID (get from https://cloud.walletconnect.com/)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
