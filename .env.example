# ============================================================================
# DataCloud Environment Variables
# Copy this file to .env.local and fill in the values
# ============================================================================

# --- Required for file uploads (IPFS/Filecoin storage via Lighthouse) ---
# Get your API key at: https://files.lighthouse.storage/
LIGHTHOUSE_API_KEY=b8571a40.c7144e1191f64ab2a49967de42f00211

# --- Required for on-chain contract interactions ---
# Deploy contracts first: WALLET_PRIVATE_KEY=0x... ./scripts/deploy.sh
DATASET_REGISTRY_ADDRESS=0xD8e68D4334292dc305e26b1ea75a345fb7241021
QUERY_MARKET_ADDRESS=0x4B1d386fbFd674b5028eAa2650b57f100795E353

# --- Server wallet for contract interactions ---
# This wallet is used as the "operator" for completing query orders
WALLET_PRIVATE_KEY=0x57c21a65bab73ed5eaec1328814b9efce9f0c98d33899524a3b29743ca1b2996

# --- Filecoin RPC ---
FILECOIN_RPC_URL=https://api.calibration.node.glif.io/rpc/v1

# --- Smart contract addresses (exposed to frontend for wallet interactions) ---
NEXT_PUBLIC_QUERY_MARKET_ADDRESS=0x4B1d386fbFd674b5028eAa2650b57f100795E353
NEXT_PUBLIC_DATASET_REGISTRY_ADDRESS=0xD8e68D4334292dc305e26b1ea75a345fb7241021

# --- WalletConnect (for frontend wallet connection) ---
# Get your project ID at: https://cloud.walletconnect.com/
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=